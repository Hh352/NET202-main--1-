@model IEnumerable<ASM.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_AdminLayout";
}

<!-- Thống kê & Thêm mới -->
<div class="admin-card mb-4 border-0 shadow-sm">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h5 class="mb-1 fw-bold">Tổng số danh mục: <span class="text-primary">@Model.Count()</span></h5>
            <p class="text-muted mb-0 small">Các danh mục này giúp phân loại sản phẩm trên Website.</p>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary px-4 fw-bold rounded-pill" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                <i class="fas fa-plus me-2"></i>Thêm danh mục
            </button>
        </div>
    </div>
</div>

<!-- Bảng danh sách danh mục -->
<div class="admin-card p-0 overflow-hidden border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4" style="width: 80px;">ID</th>
                    <th>Tên danh mục</th>
                    <th>Mô tả</th>
                    <th class="text-center">Số lượng món</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">#@item.CategoryId</td>
                        <td><strong class="text-dark">@item.CategoryName</strong></td>
                        <td><span class="text-muted small">@(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)</span></td>
                        <td class="text-center">
                            <span class="badge rounded-pill bg-info text-white px-3">@item.Products?.Count() món</span>
                        </td>
                        <td>
                            <form asp-action="ToggleCategoryStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.CategoryId" />
                                <div class="form-check form-switch cursor-pointer" onclick="this.closest('form').submit()">
                                    <input class="form-check-input" type="checkbox" @(item.Status == "Active" ? "checked" : "")>
                                    <label class="form-check-label @(item.Status == "Active" ? "text-success fw-bold" : "text-muted")" style="font-size: 0.85rem;">
                                        @(item.Status == "Active" ? "Công khai" : "Đã ẩn")
                                    </label>
                                </div>
                            </form>
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#editCategoryModal-@item.CategoryId">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form asp-action="DeleteCategory" method="post" class="d-inline" onsubmit="return confirm('Mọi sản phẩm thuộc danh mục này sẽ bị ảnh hưởng. Bạn vẫn muốn xóa?')">
                                <input type="hidden" name="id" value="@item.CategoryId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Modal Sửa Danh Mục -->
                    <div class="modal fade" id="editCategoryModal-@item.CategoryId" tabindex="-1">
                        <div class="modal-dialog">
                            <form asp-action="EditCategory" method="post" class="modal-content border-0 shadow">
                                <div class="modal-header border-bottom-0">
                                    <h5 class="modal-title fw-bold">Chỉnh sửa danh mục</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body p-4">
                                    <input type="hidden" name="categoryId" value="@item.CategoryId" />
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Tên danh mục</label>
                                        <input type="text" name="categoryName" value="@item.CategoryName" class="form-control rounded-3" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Mô tả</label>
                                        <textarea name="description" class="form-control rounded-3" rows="3">@item.Description</textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Hiển thị</label>
                                        <select name="status" class="form-select rounded-3">
                                            <option value="Active" selected="@(item.Status == "Active")">Công khai trên Website</option>
                                            <option value="Hidden" selected="@(item.Status == "Hidden")">Ẩn khỏi khách hàng</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="modal-footer border-top-0">
                                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                                    <button type="submit" class="btn btn-primary rounded-pill px-4">Cập nhật</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm Danh Mục -->
<div class="modal fade" id="addCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateCategory" method="post" class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold">Thêm danh mục mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên danh mục</label>
                    <input type="text" name="categoryName" class="form-control rounded-3" placeholder="Ví dụ: Bánh ngọt, Đồ ăn vặt..." required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea name="description" class="form-control rounded-3" rows="3" placeholder="Thông tin tóm tắt..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo ngay</button>
            </div>
        </form>
    </div>
</div>
