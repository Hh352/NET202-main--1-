@model IEnumerable<ASM.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4 bg-white rounded-3 shadow-sm">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa fa-exclamation-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold"><i class="fa fa-tags text-primary me-2"></i>Quản lý Danh mục</h4>
            <small class="text-muted">Tổng cộng @Model.Count() danh mục thực đơn</small>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
            <i class="fa fa-plus-circle"></i> THÊM DANH MỤC
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border-top">
            <thead class="bg-light">
                <tr>
                    <th class="py-3 px-4" style="width: 100px;">MÃ ID</th>
                    <th class="py-3 px-4">TÊN DANH MỤC</th>
                    <th class="py-3 px-4 text-center" style="width: 150px;">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="px-4"><span class="badge bg-secondary">#@item.CategoryId</span></td>
                        <td class="px-4 fw-bold text-dark">@item.CategoryName</td>
                        <td class="px-4">
                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editModal-@item.CategoryId" title="Chỉnh sửa">
                                    <i class="fa fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.CategoryId" title="Xóa">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editModal-@item.CategoryId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <form asp-action="EditCategory" method="post">
                                    <input type="hidden" name="categoryId" value="@item.CategoryId" />
                                    <div class="modal-header">
                                        <h5 class="modal-title fw-bold">Chỉnh sửa danh mục</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Tên danh mục mới</label>
                                            <input type="text" name="categoryName" value="@item.CategoryName" class="form-control" required maxlength="50" pattern="^[\p{L}\s\d]+$" title="Tên danh mục không chứa ký tự đặc biệt" />
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Modal -->
                    <div class="modal fade" id="deleteModal-@item.CategoryId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-body text-center p-4">
                                    <div class="text-danger mb-3"><i class="fa fa-exclamation-triangle fa-3x"></i></div>
                                    <h5 class="fw-bold mb-3">Xác nhận xóa?</h5>
                                    <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa danh mục <strong>"@item.CategoryName"</strong>? Hành động này không thể hoàn tác.</p>
                                    <form asp-action="DeleteCategory" method="post">
                                        <input type="hidden" name="id" value="@item.CategoryId" />
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Hủy</button>
                                            <button type="submit" class="btn btn-danger px-4">Xóa ngay</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="CreateCategory" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Thêm Danh Mục Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên danh mục *</label>
                        <input type="text" name="categoryName" class="form-control form-control-lg" placeholder="Ví dụ: Đồ uống, Tráng miệng..." required maxlength="50" pattern="^[\p{L}\s\d]+$" title="Tên danh mục không chứa ký tự đặc biệt" />
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Tạo Danh Mục</button>
                </div>
            </form>
        </div>
    </div>
</div>
