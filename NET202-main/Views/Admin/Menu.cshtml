@model IEnumerable<ASM.Models.Product>
@{
    ViewData["Title"] = "Quản lý Thực đơn";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4 bg-white rounded-4 shadow-sm">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 bg-success bg-opacity-10 text-success" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 bg-danger bg-opacity-10 text-danger" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> <strong>Thất bại!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h4 class="mb-1 fw-bold text-dark"><i class="fa-solid fa-utensils text-primary me-2"></i>Quản lý Thực đơn</h4>
            <p class="text-muted small mb-0">Hệ thống đang hiển thị @Model.Count() món ăn/đồ uống</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center justify-content-center gap-2 px-4 py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#addProductModal">
            <i class="fa-solid fa-plus"></i> THÊM MÓN MỚI
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light border-bottom">
                <tr class="text-uppercase small fw-bold text-muted">
                    <th class="ps-4">Sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Đơn giá</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(string.IsNullOrEmpty(item.Image) ? "/Images/default.png" : (item.Image.Contains("http") ? item.Image : $"/Images/{item.Image}"))" class="rounded-3 shadow-sm border" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.src='/Images/default.png'" />
                                <div>
                                    <div class="fw-bold text-dark mb-0">@item.ProductName</div>
                                    <small class="text-muted">ID: #@item.ProductId</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border fw-medium px-3 py-2 rounded-pill">
                                @(item.Category?.CategoryName ?? "Chưa phân loại")
                            </span>
                        </td>
                        <td>
                            <span class="fw-bold text-dark">@item.Price.ToString("N0") VNĐ</span>
                        </td>
                        <td class="text-center">
                            @if (item.Status == "Active") { <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check-circle me-1"></i>Đang bán</span> }
                            else { <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-pause me-1"></i>Đã ẩn</span> }
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-icon btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editProductModal-@item.ProductId" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-icon btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteProductModal-@item.ProductId" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Edit Product Modal -->
                    <div class="modal fade" id="editProductModal-@item.ProductId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content overflow-hidden border-0 shadow">
                                <form asp-action="EditMenuItem" method="post" enctype="multipart/form-data">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <div class="modal-header bg-warning py-3">
                                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Chỉnh sửa món ăn</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body p-4">
                                        <div class="row g-3">
                                            <div class="col-md-6 text-center border-end">
                                                <div class="mb-3">
                                                    <label class="form-label d-block fw-bold text-muted">Hình ảnh hiện tại</label>
                                                    <img id="preview-@item.ProductId" src="@(string.IsNullOrEmpty(item.Image) ? "/Images/default.png" : (item.Image.Contains("http") ? item.Image : $"/Images/{item.Image}"))" class="img-fluid rounded-3 shadow-sm border" style="max-height: 200px; object-fit: cover;" onerror="this.src='/Images/default.png'" />
                                                </div>
                                                <input type="file" name="newImage" class="form-control" accept="image/*" onchange="previewImage(this, 'preview-@item.ProductId')" />
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Tên món ăn <span class="text-danger">*</span></label>
                                                    <input type="text" name="productName" value="@item.ProductName" class="form-control" required maxlength="100" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                                                    <select name="categoryId" class="form-select" required>
                                                        @foreach (var cat in (IEnumerable<ASM.Models.Category>)ViewBag.Categories) { <option value="@cat.CategoryId" selected="@(cat.CategoryId == item.CategoryId)">@cat.CategoryName</option> }
                                                    </select>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                                    <input type="number" name="price" value="@item.Price" class="form-control" required min="10" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold text-muted">Mô tả món ăn</label>
                                                    <textarea name="description" class="form-control" rows="3">@item.Description</textarea>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer bg-light border-0">
                                        <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                                        <button type="submit" class="btn btn-warning px-4 fw-bold">LƯU THAY ĐỔI</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Product Modal -->
                    <div class="modal fade" id="deleteProductModal-@item.ProductId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content text-center p-4 border-0 shadow">
                                <div class="text-danger mb-3"><i class="fa-solid fa-circle-exclamation fa-3x"></i></div>
                                <h4 class="fw-bold text-dark">Xác nhận xóa?</h4>
                                <p class="text-muted">Bạn có chắc muốn món <strong>@item.ProductName</strong> khỏi thực đơn? Hệ thống sẽ ẩn sản phẩm nếu đã có đơn hàng.</p>
                                <form asp-action="DeleteMenuItem" method="post" class="mt-4">
                                    <input type="hidden" name="id" value="@item.ProductId" />
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Hủy</button>
                                        <button type="submit" class="btn btn-danger px-4 fw-bold">XÓA/ẨN NGAY</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content overflow-hidden border-0 shadow">
            <form asp-action="CreateMenuItem" method="post" enctype="multipart/form-data">
                <div class="modal-header bg-primary py-3">
                    <h5 class="modal-title fw-bold text-white"><i class="fa-solid fa-plus-circle me-2"></i>Thêm Món Ăn Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-5 text-center border-end">
                            <div class="mb-3">
                                <label class="form-label d-block fw-bold text-muted">Ảnh minh họa</label>
                                <div class="border rounded-4 bg-light p-2 mb-2 d-flex align-items-center justify-content-center" style="height: 200px; border-style: dashed !important;">
                                    <img id="previewAdd" src="#" class="img-fluid rounded-3" style="max-height: 100%; display:none;" />
                                    <div id="previewPlaceholder" class="text-muted small">
                                        <i class="fa-regular fa-image fa-3x mb-2 d-block opacity-25"></i>
                                        Chưa có ảnh
                                    </div>
                                </div>
                                <input type="file" name="image" class="form-control" accept="image/*" required onchange="previewImage(this, 'previewAdd')" />
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Tên món ăn đồ uống <span class="text-danger">*</span></label>
                                <input type="text" name="productName" class="form-control form-control-lg bg-light" placeholder="Nhập tên sản phẩm..." required maxlength="100" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Phân loại danh mục <span class="text-danger">*</span></label>
                                <select name="categoryId" class="form-select bg-light" required>
                                    <option value="" disabled selected>-- Chọn danh mục --</option>
                                    @foreach (var cat in (IEnumerable<ASM.Models.Category>)ViewBag.Categories) { <option value="@cat.CategoryId">@cat.CategoryName</option> }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Giá niêm yết (VNĐ) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input type="number" name="price" class="form-control bg-light" placeholder="0" required min="10" />
                                    <span class="input-group-text">đ</span>
                                </div>
                            </div>
                            <div class="mb-0">
                                <label class="form-label fw-bold small text-muted">Mô tả ngắn</label>
                                <textarea name="description" class="form-control bg-light" rows="2" placeholder="VD: Cappuccino nóng với lớp bọt sữa dày..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">ĐÓNG</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold text-uppercase">Tạo Sản Phẩm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(input, targetId) {
        let preview = document.getElementById(targetId);
        let placeholder = document.getElementById('previewPlaceholder');
        if (input.files && input.files[0]) {
            let reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
                if(placeholder) placeholder.style.display = 'none';
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

<style>
    .btn-icon { width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; padding: 0; border-radius: 8px; transition: all 0.2s; }
    .bg-success-subtle { background-color: rgba(25, 135, 84, 0.1) !important; color: #198754 !important; }
    .bg-danger-subtle { background-color: rgba(220, 53, 69, 0.1) !important; color: #dc3545 !important; }
</style>