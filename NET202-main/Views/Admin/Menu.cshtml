@model IEnumerable<ASM.Models.Product>
@{
    ViewData["Title"] = "Quản lý Thực đơn";
    Layout = "_AdminLayout";
    var categories = ViewBag.Categories as IEnumerable<ASM.Models.Category>;
}

<!-- Bộ lọc & Tìm kiếm -->
<div class="admin-card mb-4">
    <div class="row g-3 align-items-center">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" id="searchMenu" class="form-control border-start-0 ps-0" placeholder="Tìm tên món..." onkeyup="filterMenu()">
            </div>
        </div>
        <div class="col-md-3">
            <select id="categoryFilter" class="form-select" onchange="filterMenu()">
                <option value="">Tất cả danh mục</option>
                @foreach(var cat in categories ?? new List<ASM.Models.Category>()) {
                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select id="statusFilter" class="form-select" onchange="filterMenu()">
                <option value="">Tất cả trạng thái</option>
                <option value="Active">Đang bán</option>
                <option value="Hidden">Ngừng bán</option>
            </select>
        </div>
        <div class="col-md-2 text-end">
            <button class="btn btn-primary w-100 fw-bold" data-bs-toggle="modal" data-bs-target="#addMenuModal">
                <i class="fas fa-plus me-2"></i>Thêm món
            </button>
        </div>
    </div>
</div>

<!-- Bảng danh sách món ăn -->
<div class="admin-card p-0 overflow-hidden shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="menuTable">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Món ăn</th>
                    <th>Danh mục</th>
                    <th>Giá bán</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr data-category="@item.CategoryId" data-status="@item.Status">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="/Images/@item.Image" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover; border: 1px solid #eee;" onerror="this.src='/Images/default.png'">
                                <div>
                                    <h6 class="mb-0 item-name fw-bold">@item.ProductName</h6>
                                    <small class="text-muted">ID: #@item.ProductId</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border">@(item.Category?.CategoryName ?? "Chưa phân loại")</span></td>
                        <td><strong class="text-danger">@item.Price.ToString("N0")đ</strong></td>
                        <td>
                            <form asp-action="ToggleMenuItemStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.ProductId" />
                                <div class="form-check form-switch cursor-pointer" onclick="this.closest('form').submit()">
                                    <input class="form-check-input" type="checkbox" role="switch" @(item.Status == "Active" ? "checked" : "")>
                                    <label class="form-check-label @(item.Status == "Active" ? "text-success fw-bold" : "text-muted")" style="font-size: 0.85rem;">
                                        @(item.Status == "Active" ? "Đang bán" : "Ngừng bán")
                                    </label>
                                </div>
                            </form>
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#editMenuModal-@item.ProductId">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form asp-action="DeleteMenuItem" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa món này không?')">
                                <input type="hidden" name="id" value="@item.ProductId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@foreach (var item in Model)
{
    <!-- Modal Sửa Món Ăn -->
    <div class="modal fade" id="editMenuModal-@item.ProductId" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="EditMenuItem" method="post" enctype="multipart/form-data" class="modal-content border-0 shadow">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold">Chỉnh sửa món ăn</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="productId" value="@item.ProductId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên món</label>
                        <input type="text" name="productName" value="@item.ProductName" class="form-control rounded-3" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Giá bán</label>
                            <input type="number" name="price" value="@item.Price" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Danh mục</label>
                            <select name="categoryId" class="form-select rounded-3">
                                @foreach (var cat in categories ?? new List<ASM.Models.Category>())
                                {
                                    <option value="@cat.CategoryId" selected="@(item.CategoryId == cat.CategoryId)">@cat.CategoryName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả</label>
                        <textarea name="description" class="form-control rounded-3" rows="3">@item.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Hình ảnh mới (nếu có)</label>
                        <input type="file" name="newImage" class="form-control rounded-3">
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
}

<!-- Modal Thêm Món Ăn -->
<div class="modal fade" id="addMenuModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateMenuItem" method="post" enctype="multipart/form-data" class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold">Thêm món ăn mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên món</label>
                    <input type="text" name="productName" class="form-control rounded-3" placeholder="Ví dụ: Cà phê Muối" required>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán</label>
                        <input type="number" name="price" class="form-control rounded-3" placeholder="Ví dụ: 35000" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Danh mục</label>
                        <select name="categoryId" class="form-select rounded-3">
                            @foreach(var cat in categories ?? new List<ASM.Models.Category>()) {
                                <option value="@cat.CategoryId">@cat.CategoryName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea name="description" class="form-control rounded-3" rows="3" placeholder="Vị cà phê đậm đà..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Hình ảnh</label>
                    <input type="file" name="image" class="form-control rounded-3" required>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Thêm ngay</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function filterMenu() {
            var input = document.getElementById("searchMenu").value.toLowerCase();
            var categoryFilter = document.getElementById("categoryFilter").value;
            var statusFilter = document.getElementById("statusFilter").value;
            
            document.querySelectorAll("#menuTable tbody tr[data-category]").forEach(row => {
                var textMatch = row.querySelector(".item-name").innerText.toLowerCase().includes(input);
                var catMatch = !categoryFilter || row.dataset.category === categoryFilter;
                var statusMatch = !statusFilter || row.dataset.status === statusFilter;
                
                row.style.display = (textMatch && catMatch && statusMatch) ? "" : "none";
            });
        }
    </script>
}