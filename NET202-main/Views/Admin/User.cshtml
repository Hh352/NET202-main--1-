@model IEnumerable<ASM.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "_AdminLayout";
}

<div class="admin-card mb-4 border-0 shadow-sm">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h5 class="mb-1 fw-bold">Thành viên hệ thống: <span class="text-primary">@Model.Count()</span></h5>
            <p class="text-muted mb-0 small">Quản lý phân quyền và trạng thái hoạt động của nhân viên và khách hàng.</p>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary px-4 fw-bold rounded-pill" data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="fas fa-user-plus me-2"></i>Thêm người dùng
            </button>
        </div>
    </div>
</div>

<div class="admin-card p-0 overflow-hidden border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Người dùng</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(user.Avatar) ? "/Images/default.png" : "/Images/" + user.Avatar)" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;" onerror="this.src='/Images/default.png'">
                                <div>
                                    <div class="fw-bold">@user.FullName</div>
                                    <small class="text-muted">ID: #@user.UserId</small>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            @if(user.Role == 2) { <span class="badge bg-danger">Admin</span> }
                            else if(user.Role == 1) { <span class="badge bg-warning text-dark">Staff</span> }
                            else { <span class="badge bg-secondary">User</span> }
                        </td>
                        <td><small>@user.CreatedAt.ToString("dd/MM/yyyy")</small></td>
                        <td>
                            <form asp-action="ToggleUserStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@user.UserId" />
                                <div class="form-check form-switch cursor-pointer" onclick="this.closest('form').submit()">
                                    <input class="form-check-input" type="checkbox" @(user.Status == "Active" ? "checked" : "")>
                                    <label class="form-check-label @(user.Status == "Active" ? "text-success fw-bold" : "text-danger fw-bold")" style="font-size: 0.8rem;">
                                        @(user.Status == "Active" ? "Hoạt động" : "Bị khóa")
                                    </label>
                                </div>
                            </form>
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1" data-bs-toggle="modal" data-bs-target="#editUserModal-@user.UserId">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Xác nhận xóa người dùng này?')">
                                <input type="hidden" name="id" value="@user.UserId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm Người Dùng (Rút gọn) -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateUser" method="post" class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold">Thêm thành viên mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên</label>
                    <input type="text" name="fullName" class="form-control rounded-3" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input type="email" name="email" class="form-control rounded-3" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input type="password" name="password" class="form-control rounded-3" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Vai trò</label>
                    <select name="role" class="form-select rounded-3">
                        <option value="0">Khách hàng (User)</option>
                        <option value="1">Nhân viên (Staff)</option>
                        <option value="2">Quản trị viên (Admin)</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo tài khoản</button>
            </div>
        </form>
    </div>
</div>
