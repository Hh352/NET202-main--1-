@model IEnumerable<ASM.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var totalOrders = Model.Count();
    var processingCount = Model.Count(o => o.OrderStatus >= 1 && o.OrderStatus <= 3);
    var todayRevenue = Model.Where(o => o.OrderStatus == 4 && o.CreatedAt.Date == DateTime.Today).Sum(o => o.FinalAmount);
}

<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        theme: {
            extend: {
                fontFamily: {
                    sans: ['Inter', 'sans-serif'],
                }
            }
        }
    }
</script>

<style>
    .receipt-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .receipt-overlay.show { display: flex; opacity: 1; }
    .receipt-card {
        display: flex; flex-direction: column; align-items: center; padding: 28px 32px; gap: 14px;
        width: 100%; max-width: 450px; background: #FFFFFF; border-radius: 40px; position: relative;
        box-shadow: 0px 13px 40px rgba(170, 170, 170, 0.12); transform: translateY(20px); transition: transform 0.3s ease;
        max-height: 90vh; overflow-y: auto;
    }
    .receipt-overlay.show .receipt-card { transform: translateY(0); }
    .r-icon { width: 56px; height: 56px; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 24px; flex-shrink: 0; background: #e8f5e9; color: #10b981; }
    .r-icon.unpaid { background: #fff7ed; color: #f59e0b; }
    .r-icon.cancelled { background: #fee2e2; color: #ef4444; }
    .r-title { font-size: 15px; color: #6b7280; font-weight: 700; margin-top: -5px; }
    .r-amount { font-size: 32px; font-weight: 900; color: #111827; }
    .r-divider { width: 100%; border-top: 1px solid #f3f4f6; margin: 4px 0; }
    .r-row { display: flex; justify-content: space-between; width: 100%; font-size: 14px; }
    .r-label { color: #6b7280; font-weight: 500; }
    .r-value { color: #111827; font-weight: 700; text-align: right; }
    
    @@media print {
        body * { visibility: hidden; }
        .receipt-overlay.show, .receipt-overlay.show .receipt-card, .receipt-overlay.show .receipt-card * { visibility: visible; }
        .receipt-overlay.show { position: absolute; left: 0; top: 0; background: #fff; }
        .receipt-card { box-shadow: none; border: 1px solid #eee; transform: none; width: 80mm; max-width: 80mm; padding: 15px; }
        .no-print { display: none !important; }
    }
</style>

<div class="p-8 bg-gray-50 min-h-screen font-sans text-gray-800 no-print">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
                <i class="fa-solid fa-file-invoice-dollar text-emerald-600"></i> Quản lý Đơn hàng
            </h1>
            <p class="text-gray-500 text-sm mt-1">Theo dõi tiến độ thực hiện các đơn hàng</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
            <div class="w-14 h-14 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center text-2xl"><i class="fa-solid fa-receipt"></i></div>
            <div><p class="text-xs font-bold text-gray-400 uppercase mb-1">Tổng đơn</p><p class="text-2xl font-black text-gray-900">@totalOrders</p></div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
            <div class="w-14 h-14 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center text-2xl"><i class="fa-solid fa-clock-rotate-left"></i></div>
            <div><p class="text-xs font-bold text-gray-400 uppercase mb-1">Chờ xử lý</p><p class="text-2xl font-black text-gray-900">@processingCount</p></div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
            <div class="w-14 h-14 rounded-xl bg-emerald-50 text-emerald-500 flex items-center justify-center text-2xl"><i class="fa-solid fa-hand-holding-dollar"></i></div>
            <div><p class="text-xs font-bold text-gray-400 uppercase mb-1">Doanh thu hôm nay</p><p class="text-2xl font-black text-emerald-600">@todayRevenue.ToString("N0")đ</p></div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-xs text-gray-500 uppercase font-bold">
                    <th class="p-5">Mã đơn</th>
                    <th class="p-5">Khách hàng</th>
                    <th class="p-5">Thời gian</th>
                    <th class="p-5">Tổng tiền</th>
                    <th class="p-5 text-center">Trạng thái</th>
                    <th class="p-5 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var o in Model)
                {
                    <tr class="border-b border-gray-50 hover:bg-gray-50/50">
                        <td class="p-5 font-bold text-gray-900">#ORD-@o.OrderId.ToString("D4")</td>
                        <td class="p-5">
                            <div class="font-bold text-gray-900">@(o.User?.FullName ?? "Khách hệ thống")</div>
                            <div class="text-xs text-gray-400">@o.User?.Email</div>
                        </td>
                        <td class="p-5 text-gray-600">
                            <div>@o.CreatedAt.ToString("dd/MM/yyyy")</div>
                            <span class="text-xs text-gray-400">@o.CreatedAt.ToString("HH:mm")</span>
                        </td>
                        <td class="p-5 font-bold text-gray-900">@o.FinalAmount.ToString("N0")đ</td>
                        <td class="p-5 text-center">
                            <form asp-action="UpdateOrderStatus" method="post" class="flex items-center justify-center gap-2">
                                <input type="hidden" name="orderId" value="@o.OrderId" />
                                <select name="orderStatus" onchange="this.form.submit()" class="px-2 py-1 text-xs font-bold rounded-lg border-none focus:ring-0 @(o.OrderStatus==1?"bg-blue-100 text-blue-700":o.OrderStatus==2?"bg-amber-100 text-amber-700":o.OrderStatus==3?"bg-indigo-100 text-indigo-700":o.OrderStatus==4?"bg-emerald-100 text-emerald-700":"bg-red-100 text-red-700")">
                                    <option value="1" selected="@(o.OrderStatus == 1)">Mới</option>
                                    <option value="2" selected="@(o.OrderStatus == 2)">Chuẩn bị</option>
                                    <option value="3" selected="@(o.OrderStatus == 3)">Đang giao</option>
                                    <option value="4" selected="@(o.OrderStatus == 4)">Hoàn thành</option>
                                    <option value="5" selected="@(o.OrderStatus == 5)">Đã hủy</option>
                                </select>
                            </form>
                        </td>
                        <td class="p-5 text-end">
                            <button onclick="openBill(@o.OrderId)" class="w-8 h-8 rounded-lg bg-gray-100 text-gray-500 hover:bg-emerald-600 hover:text-white transition-colors">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@foreach(var o in Model)
{
    <div id="bill-@o.OrderId" class="receipt-overlay" onclick="closeBill(@o.OrderId)">
        <div class="receipt-card" onclick="event.stopPropagation()">
            <button class="absolute top-6 right-6 text-gray-400 hover:text-red-500 no-print" onclick="closeBill(@o.OrderId)"><i class="fa-solid fa-xmark text-xl"></i></button>
            
            <div class="r-icon @(o.OrderStatus==5?"cancelled":o.OrderStatus==4?"":"unpaid")"><i class="fa-solid @(o.OrderStatus==5?"fa-ban":o.OrderStatus==4?"fa-check":"fa-clock")"></i></div>
            <div class="r-title">HÓA ĐƠN THANH TOÁN</div>
            <div class="r-amount">@o.FinalAmount.ToString("N0")đ</div>
            <div class="r-divider"></div>

            <div class="r-row"><span class="r-label">Mã đơn</span><span class="r-value font-mono">#ORD-@o.OrderId.ToString("D4")</span></div>
            <div class="r-row"><span class="r-label">Thời gian</span><span class="r-value">@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
            <div class="r-row"><span class="r-label">Khách hàng</span><span class="r-value">@(o.User?.FullName ?? "Khách lẻ")</span></div>
            <div class="r-row"><span class="r-label">Thanh toán</span><span class="r-value">@(o.PaymentMethod == 1 ? "Tiền mặt" : "Chuyển khoản")</span></div>

            <div class="r-divider" style="border-top-style: dashed;"></div>
            <div class="w-full">
                @foreach (var d in o.OrderDetails) {
                    <div class="r-row mb-2">
                        <span class="r-label text-gray-800">@(d.Product?.ProductName) <span class="text-xs text-gray-400 ml-1">x@d.Quantity</span></span>
                        <span class="r-value">@((d.Price*d.Quantity).ToString("N0"))đ</span>
                    </div>
                }
            </div>
            <div class="r-divider" style="border-top-style: dashed;"></div>

            <div class="r-row"><span class="r-label">Tạm tính</span><span class="r-value">@o.TotalAmount.ToString("N0")đ</span></div>
            @if(o.Voucher != null) {
                <div class="r-row"><span class="r-label">Giảm giá (@o.Voucher.Code)</span><span class="r-value text-red-500">-@((o.TotalAmount - o.FinalAmount).ToString("N0"))đ</span></div>
            }
            <div class="r-row font-bold"><span class="r-label text-gray-900">TỔNG CỘNG</span><span class="r-value text-xl">@o.FinalAmount.ToString("N0")đ</span></div>

            <button class="no-print mt-4 w-full py-3 rounded-2xl bg-emerald-600 text-white font-bold flex justify-center items-center gap-2" onclick="window.print()">
                <i class="fa-solid fa-print"></i> IN HÓA ĐƠN
            </button>
        </div>
    </div>
}

@section Scripts {
    <script>
        function openBill(id) { document.getElementById('bill-' + id).classList.add('show'); }
        function closeBill(id) { document.getElementById('bill-' + id).classList.remove('show'); }
    </script>
}