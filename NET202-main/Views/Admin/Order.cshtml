@model IEnumerable<ASM.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "_AdminLayout";
}

<style>
    /* RESET TRIỆT ĐỂ BẢNG */
    .fix-table-wrapper table { display: table !important; width: 100% !important; border-collapse: separate !important; border-spacing: 0 10px !important; }
    .fix-table-wrapper thead { display: table-header-group !important; }
    .fix-table-wrapper tbody { display: table-row-group !important; }
    .fix-table-wrapper tr { display: table-row !important; background: #fff !important; }
    .fix-table-wrapper td, .fix-table-wrapper th { 
        display: table-cell !important; 
        vertical-align: middle !important; 
        padding: 15px !important; 
        border: none !important;
        background: #fff !important;
    }
    .fix-table-wrapper th { background: transparent !important; color: #888; text-transform: uppercase; font-size: 11px; font-weight: 700; }
    
    /* Hiệu ứng bo góc từng dòng */
    .fix-table-wrapper tr td:first-child { border-radius: 12px 0 0 12px !important; }
    .fix-table-wrapper tr td:last-child { border-radius: 0 12px 12px 0 !important; }
    
    .btn-chi-tiet {
        background-color: #f0f7ff;
        color: #007bff;
        border: 1px solid #d0e7ff;
        padding: 6px 16px;
        border-radius: 20px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
        transition: 0.2s;
    }
    .btn-chi-tiet:hover { background-color: #007bff; color: #fff; }
</style>

<div class="admin-card mb-4 border-0 shadow-sm">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-1 fw-bold">Danh sách đơn hàng</h5>
            <p class="text-muted mb-0 small">Theo dõi và cập nhật trạng thái đơn hàng của khách.</p>
        </div>
    </div>
</div>

<div class="fix-table-wrapper">
    <div class="table-responsive" style="overflow: visible;">
        <table class="table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">#@order.OrderId</td>
                        <td>
                            <div class="fw-bold text-dark">@order.User?.FullName</div>
                            <div class="text-muted small">@order.PhoneNumber</div>
                        </td>
                        <td><div class="small">@order.CreatedAt.ToString("dd/MM/yyyy")</div><div class="text-muted small">@order.CreatedAt.ToString("HH:mm")</div></td>
                        <td><strong class="text-dark">@order.FinalAmount.ToString("N0")đ</strong></td>
                        <td class="text-center">
                            <form asp-action="UpdateOrderStatus" method="post" class="d-inline">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <select name="orderStatus" class="form-select form-select-sm rounded-pill text-center d-inline-block" 
                                        style="width: 130px; font-weight: 600; background-color: #f8f9fa; border: 1px solid #eee;" 
                                        onchange="this.form.submit()">
                                    <option value="1" selected="@(order.OrderStatus == 1)">Chờ xác nhận</option>
                                    <option value="2" selected="@(order.OrderStatus == 2)">Đang giao</option>
                                    <option value="3" selected="@(order.OrderStatus == 3)">Đã giao</option>
                                    <option value="4" selected="@(order.OrderStatus == 4)">Hoàn thành</option>
                                    <option value="5" selected="@(order.OrderStatus == 5)">Đã hủy</option>
                                </select>
                            </form>
                        </td>
                        <td class="text-end pe-4">
                            <button type="button" class="btn-chi-tiet" data-bs-toggle="modal" data-bs-target="#orderDetailModal-@order.OrderId">
                                <i class="fas fa-eye me-1"></i> Chi tiết
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@foreach (var order in Model)
{
    <!-- Modal Chi Tiết Đơn Hàng (Đã đưa ra ngoài bảng) -->
    <div class="modal fade" id="orderDetailModal-@order.OrderId" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold">Chi tiết đơn hàng #@order.OrderId</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-dark">
                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <p class="mb-1 fw-bold">Thông tin nhận hàng:</p>
                            <p class="mb-1">@order.User?.FullName</p>
                            <p class="mb-1 text-muted">@order.PhoneNumber</p>
                            <p class="mb-0 text-muted">@order.ShippingAddress</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1 fw-bold">Tóm tắt:</p>
                            <p class="mb-1">Loại thanh toán: <span class="badge bg-light text-dark border">@(order.PaymentMethod == 1 ? "Momo" : "Tiền mặt")</span></p>
                            <p class="mb-0">Voucher dùng: <span class="text-success fw-bold">@(order.Voucher?.Code ?? "Không")</span></p>
                        </div>
                    </div>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in order.OrderDetails ?? new List<ASM.Models.OrderDetail>())
                            {
                                <tr>
                                    <td>@detail.Product?.ProductName</td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end">@detail.Price.ToString("N0")đ</td>
                                    <td class="text-end fw-bold">@((detail.Quantity * detail.Price).ToString("N0"))đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-end text-danger fw-bold fs-5">@order.FinalAmount.ToString("N0")đ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
}