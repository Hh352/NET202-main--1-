@model IEnumerable<ASM.Models.Voucher>
@{
    ViewData["Title"] = "Quản lý Khuyến mãi";
    Layout = "_AdminLayout";
}

<div class="admin-card mb-4 border-0 shadow-sm">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h5 class="mb-1 fw-bold">Chiến dịch khuyến mãi: <span class="text-primary">@Model.Count()</span></h5>
            <p class="text-muted mb-0 small">Phát hành mã giảm giá để tăng doanh số bán hàng.</p>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary px-4 fw-bold rounded-pill" data-bs-toggle="modal" data-bs-target="#addVoucherModal">
                <i class="fas fa-plus me-2"></i>Tạo mã mới
            </button>
        </div>
    </div>
</div>

<div class="admin-card p-0 overflow-hidden border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Mã Voucher</th>
                    <th>Giá trị</th>
                    <th>Hiệu lực</th>
                    <th class="text-center">Sử dụng</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var voucher in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-uppercase fs-6" style="letter-spacing: 1px; color: #d97706;">@voucher.Code</div>
                            <small class="text-muted">@voucher.Name</small>
                        </td>
                        <td>
                            @if(voucher.DiscountType == 1) { <span class="fw-bold">@voucher.DiscountValue.ToString("N0")%</span> }
                            else { <span class="fw-bold">@voucher.DiscountValue.ToString("N0")đ</span> }
                        </td>
                        <td>
                            <div class="small">Từ: @voucher.StartDate.ToString("dd/MM/yyyy")</div>
                            <div class="small text-danger">Đến: @voucher.EndDate.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">@voucher.Orders?.Count() / @voucher.UsageLimit</span>
                        </td>
                        <td>
                            <form asp-action="ToggleVoucherStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@voucher.VoucherId" />
                                <div class="form-check form-switch cursor-pointer" onclick="this.closest('form').submit()">
                                    <input class="form-check-input" type="checkbox" @(voucher.Status == "Active" ? "checked" : "")>
                                    <label class="form-check-label @(voucher.Status == "Active" ? "text-success fw-bold" : "text-muted")" style="font-size: 0.8rem;">
                                        @(voucher.Status == "Active" ? "Hoạt động" : "Bị khóa")
                                    </label>
                                </div>
                            </form>
                        </td>
                        <td class="text-end pe-4">
                            <form asp-action="DeleteVoucher" method="post" class="d-inline" onsubmit="return confirm('Xác nhận xóa mã này?')">
                                <input type="hidden" name="id" value="@voucher.VoucherId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm Voucher (Rút gọn) -->
<div class="modal fade" id="addVoucherModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateVoucher" method="post" class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold">Tạo mã khuyến mãi mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Mã CODE</label>
                    <input type="text" name="Code" class="form-control rounded-3 text-uppercase" placeholder="Ví dụ: SALE50" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên chương trình</label>
                    <input type="text" name="Name" class="form-control rounded-3" required>
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">Loại giảm</label>
                        <select name="DiscountType" class="form-select rounded-3">
                            <option value="1">Theo phần trăm (%)</option>
                            <option value="2">Số tiền cố định (đ)</option>
                        </select>
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">Giá trị</label>
                        <input type="number" name="DiscountValue" class="form-control rounded-3" required>
                    </div>
                </div>
                <!-- Các trường khác như StartDate, EndDate nên để mặc định hoặc bổ sung nếu cần -->
                <input type="hidden" name="StartDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="EndDate" value="@DateTime.Now.AddMonths(1).ToString("yyyy-MM-dd")" />
                <input type="hidden" name="UsageLimit" value="100" />
                <input type="hidden" name="Status" value="Active" />
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo mã</button>
            </div>
        </form>
    </div>
</div>
