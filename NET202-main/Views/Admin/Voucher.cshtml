@model IEnumerable<ASM.Models.Voucher>
@{
    ViewData["Title"] = "Quản lý mã Voucher";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4 bg-white rounded-3 shadow-sm">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 bg-success bg-opacity-10 text-success" role="alert">
            <i class="fa fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 bg-danger bg-opacity-10 text-danger" role="alert">
            <i class="fa fa-exclamation-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h4 class="mb-0 fw-bold"><i class="fa fa-ticket-alt text-danger me-2"></i>Quản lý khuyến mãi</h4>
            <small class="text-muted">Đang có @Model.Count() mã voucher trong hệ thống</small>
        </div>
        <button class="btn btn-danger d-flex align-items-center gap-2 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addVoucherModal">
            <i class="fa fa-plus-circle"></i> THÊM MÃ MỚI
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="bg-light bg-opacity-50">
                <tr class="small text-muted text-uppercase fw-bold">
                    <th class="ps-4">Mã CODE</th>
                    <th>Giá trị giảm</th>
                    <th>Thời hạn</th>
                    <th class="text-center">Số lượng</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    bool isExpired = item.EndDate < DateTime.Now;
                    bool isLocked = item.Status == "Locked";
                    
                    <tr class="@(isExpired || isLocked ? "opacity-50" : "")">
                        <td class="ps-4">
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 fw-bold text-uppercase font-monospace fs-6">
                                @item.Code
                            </span>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">
                                @if(item.DiscountType == 1) { @(item.DiscountValue.ToString("N0") + "đ") }
                                else { @(item.DiscountValue + "%") }
                            </div>
                            <small class="text-muted">Đơn tối thiểu: @item.MinOrderValue.ToString("N0")đ</small>
                        </td>
                        <td>
                            <div class="@(isExpired ? "text-danger" : "text-dark")">@item.StartDate.ToString("dd/MM") - @item.EndDate.ToString("dd/MM")</div>
                            <small class="text-muted">Năm @item.EndDate.Year</small>
                        </td>
                        <td class="text-center">
                            <span class="fw-bold">@item.UsageLimit</span>
                            <div class="progress mt-1" style="height: 4px; width: 60px; margin: 0 auto;">
                                <div class="progress-bar bg-danger" style="width: 100%"></div>
                            </div>
                        </td>
                        <td class="text-center">
                            @if (isLocked) { <span class="badge bg-secondary px-3 py-2 rounded-pill">Đã khóa</span> }
                            else if (isExpired) { <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Hết hạn</span> }
                            else { <span class="badge bg-success px-3 py-2 rounded-pill">Đang chạy</span> }
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <form asp-action="ToggleVoucherStatus" method="post" style="margin: 0;">
                                    <input type="hidden" name="id" value="@item.VoucherId" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="@(isLocked ? "Mở khóa" : "Khóa")">
                                        <i class="fa @(isLocked ? "fa-lock-open" : "fa-lock")"></i>
                                    </button>
                                </form>
                                <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editVoucher-@item.VoucherId">
                                    <i class="fa fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteVoucher-@item.VoucherId">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editVoucher-@item.VoucherId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow">
                                <form asp-action="EditVoucher" method="post">
                                    <input type="hidden" name="VoucherId" value="@item.VoucherId" />
                                    <div class="modal-header">
                                        <h5 class="modal-title fw-bold">Chỉnh sửa mã @item.Code</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4">
                                        <div class="row g-3">
                                            <div class="col-12 mb-2 text-center bg-light p-3 rounded-3 border">
                                                <small class="text-muted d-block mb-1">MÃ CODE (AUTO IN HOA)</small>
                                                <input type="text" name="Code" value="@item.Code" class="form-control text-center font-monospace fw-bold text-danger fs-4" required />
                                            </div>
                                            <div class="col-12"><label class="form-label fw-bold">Tên Voucher</label><input type="text" name="Name" value="@item.Name" class="form-control" required /></div>
                                            <div class="col-6">
                                                <label class="form-label fw-bold">Loại giảm</label>
                                                <select name="DiscountType" class="form-select">
                                                    <option value="1" selected="@(item.DiscountType == 1)">Số tiền (đ)</option>
                                                    <option value="2" selected="@(item.DiscountType == 2)">Phần trăm (%)</option>
                                                </select>
                                            </div>
                                            <div class="col-6"><label class="form-label fw-bold">Giá trị</label><input type="number" name="DiscountValue" value="@item.DiscountValue" class="form-control" required min="1" /></div>
                                            <div class="col-6"><label class="form-label fw-bold">Đơn tối thiểu</label><input type="number" name="MinOrderValue" value="@item.MinOrderValue" class="form-control" required min="0" /></div>
                                            <div class="col-6"><label class="form-label fw-bold">Lượt sử dụng</label><input type="number" name="UsageLimit" value="@item.UsageLimit" class="form-control" required min="1" /></div>
                                            <div class="col-6"><label class="form-label fw-bold">Ngày bắt đầu</label><input type="datetime-local" name="StartDate" value="@item.StartDate.ToString("yyyy-MM-ddTHH:mm")" class="form-control" required /></div>
                                            <div class="col-6"><label class="form-label fw-bold">Ngày kết thúc</label><input type="datetime-local" name="EndDate" value="@item.EndDate.ToString("yyyy-MM-ddTHH:mm")" class="form-control" required /></div>
                                        </div>
                                    </div>
                                    <div class="modal-footer bg-light border-0">
                                        <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">HỦY</button>
                                        <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">LƯU CẬP NHẬT</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Modal -->
                    <div class="modal fade" id="deleteVoucher-@item.VoucherId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content p-4 text-center border-0 shadow">
                                <div class="text-danger mb-3"><i class="fa fa-times-circle fa-4x"></i></div>
                                <h3 class="fw-bold">Xóa mã voucher?</h3>
                                <p class="text-muted">Hệ thống sẽ không cho xóa nếu mã đã phát sinh đơn hàng (bạn nên khóa thay vì xóa).</p>
                                <form asp-action="DeleteVoucher" method="post" class="mt-3">
                                    <input type="hidden" name="id" value="@item.VoucherId" />
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Hủy</button>
                                        <button type="submit" class="btn btn-danger px-4 fw-bold">XÓA NGAY</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addVoucherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="CreateVoucher" method="post">
                <div class="modal-header bg-danger py-3">
                    <h5 class="modal-title fw-bold text-white"><i class="fa fa-gift me-2"></i>TẠO VOUCHER MỚI</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Mã khuyến mãi (Code) *</label>
                            <input type="text" name="Code" class="form-control text-uppercase font-monospace fw-bold" placeholder="VD: CHAOTANXUAN" required maxlength="20" />
                        </div>
                        <div class="col-12"><label class="form-label fw-bold">Tên Voucher</label><input type="text" name="Name" class="form-control" placeholder="Mô tả ngắn..." required /></div>
                        <div class="col-6">
                            <label class="form-label fw-bold">Loại giảm</label>
                            <select name="DiscountType" class="form-select">
                                <option value="1">Số tiền (đ)</option>
                                <option value="2">Phần trăm (%)</option>
                            </select>
                        </div>
                        <div class="col-6"><label class="form-label fw-bold">Giá trị</label><input type="number" name="DiscountValue" class="form-control" required min="1" /></div>
                        <div class="col-6"><label class="form-label fw-bold">Đơn tối thiểu</label><input type="number" name="MinOrderValue" class="form-control" value="0" required min="0" /></div>
                        <div class="col-6"><label class="form-label fw-bold">Số lượng phát hành</label><input type="number" name="UsageLimit" class="form-control" value="100" required min="1" /></div>
                        <div class="col-6"><label class="form-label fw-bold">Ngày bắt đầu</label><input type="datetime-local" name="StartDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required /></div>
                        <div class="col-6"><label class="form-label fw-bold">Ngày kết thúc</label><input type="datetime-local" name="EndDate" class="form-control" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:mm")" required /></div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">ĐÓNG</button>
                    <button type="submit" class="btn btn-danger px-5 fw-bold">TẠO NGAY</button>
                </div>
            </form>
        </div>
    </div>
</div>
